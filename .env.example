# fxapk 在线富化所需的 API key（本文件是模板，可入库；真实密钥写进 .env，.env 已 gitignore）。
# 用法：cp .env.example .env，把真实 key 填到对应行。**全部可选**——不填只缺对应富化能力，核心分析不受影响。
# 全程被动 OSINT（读第三方已扫库 / 公开登记），对目标零主动流量。

# ── apkscan 主项目直接使用 ──────────────────────────────────────────────

# Shodan —— 海外服务器**被动 IP 归属**取证：读 Shodan 已扫库（开放端口 / 服务 banner /
# 产品版本 / 归属 ASN·org·归属国 / 关联主机名），用于识别真实源站与并簇串案。
# 申请：https://account.shodan.io/  （注册后 Account 页可见 API Key）
FXAPK_SHODAN_KEY=

# web-check —— 自托管 OSINT 实例（lissy93/web-check）：DNS / SSL / 响应头 / 技术栈 / 端口 /
# 子域 / 威胁情报等一站式查询。**免 API key**，只需填自托管实例地址（或公共实例）。
# 部署：https://github.com/lissy93/web-check  （或公共实例 https://web-check.xyz）
FXAPK_WEBCHECK_URL=

# ── 扩展富化源（IP / 域名深度归属 · 串案用；由多源富化工具按需拉取）────────────
#  apkscan analyze 只主动用上面两项；fxapk case close 会按已配置项调用下列被动情报 / 网络空间
#  测绘服务。全部可选，不配置会在闭环来源状态中明确记为 disabled。

# FOFA（白帽汇）—— 网络空间测绘：按 IP / 证书 / 指纹反查同源资产、常捞到 DoH 看不到的历史落地 IP。
# 申请：https://fofa.info/  （注册后 个人中心 → API Key）
FXAPK_FOFA_KEY=
# FXAPK_FOFA_URL=            # 可选：自定义 API base（默认走官方）

# 360 Quake —— 国内网络空间测绘（同 FOFA 类，境内资产覆盖好）。
# 申请：https://quake.360.net/  （注册后 个人中心 → API Token）
FXAPK_QUAKE_KEY=
# FXAPK_QUAKE_KEY2=          # 可选：备用 Token；主 Token 未配置时使用
# FXAPK_QUAKE_URL=           # 可选：自定义 API base

# 奇安信 Hunter（鹰图）—— ★境内最有用：返 ICP 备案 company + as_org + 机房城市，最利于境内定人。
# 申请：https://hunter.qianxin.com/  （注册后 个人中心 → API）。★须**境内直连**（走代理常 403）。
FXAPK_HUNTER_KEY=

# ZoomEye —— 网络空间测绘，补充主机端口、产品和 ASN/地理信息。
# 申请：https://www.zoomeye.org/  （注册后获取 API Key）
FXAPK_ZOOMEYE_KEY=
# FXAPK_ZOOMEYE_URL=         # 可选：自定义 API endpoint

# Censys —— 主机、服务与自治系统被动测绘。
# 申请：https://search.censys.io/account/api  （使用 Platform API Token）
FXAPK_CENSYS_TOKEN=
# FXAPK_CENSYS_ORG_ID=       # 可选：组织 ID

# VirusTotal —— 域名 / IP / 文件威胁情报 + 历史解析（passive DNS）。
# 申请：https://www.virustotal.com/gui/join-us  （注册后 → API Key）
FXAPK_VT_KEY=

# AlienVault OTX —— 开放威胁情报 pulse + passive DNS。
# 申请：https://otx.alienvault.com/  （注册后 Settings → OTX Key）
FXAPK_OTX_KEY=

# urlscan.io —— URL 扫描历史 + 关联资源 / 截图。
# 申请：https://urlscan.io/user/signup/  （注册后 Settings → API Key）
FXAPK_URLSCAN_KEY=

# AbuseIPDB —— IP 滥用举报信誉（是否已被标记恶意）。
# 申请：https://www.abuseipdb.com/register  （注册后 Account → API）
FXAPK_ABUSEIPDB_KEY=
