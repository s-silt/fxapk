# fxapk 在线富化所需的 API key（本文件是模板，可入库；真实密钥写进 .env，.env 已 gitignore）
# 用法：cp .env.example .env，然后把真实 key 填到 .env 里对应行。

# Shodan API key —— 海外服务器攻击面被动富化（开放端口/banner/产品版本/vulns）
# 申请：https://account.shodan.io/  （注册后在 Account 页可见 API Key）
FXAPK_SHODAN_KEY=

# （可选）NVD API key —— CVE 在线补查提速（无 key 也能用，仅 5/30s 限速；有 key 提到 50/30s）
# 申请：https://nvd.nist.gov/developers/request-an-api-key
FXAPK_NVD_KEY=

# （可选·主动探测 opt-in）海外服务器主动侦查取证开关，默认关闭。
# 设为 1/true/yes/on 才启用 recon：对【国外·建议调证·公网 IP】目标做仅侦查探测
# （端口连通/TLS证书/HTTP指纹/已知后台路径），绝不漏洞利用/爆破/DoS。
# ⚠️ 这是 apkscan 唯一主动向目标发连接的功能——务必确保已获授权、在合法取证范围内使用。
# FXAPK_ACTIVE_RECON=1
# （可选）主动探测并发上限（默认 8，范围 1-64）
# FXAPK_ACTIVE_RECON_CONCURRENCY=8
