!.env.example

# CodeGraph 本地索引(生成物，类似 .git，绝不入库)
/.codegraph/

# PyInstaller 构建产物(大，绝不入库)
/build/
/dist/
# GUI 发行 zip(build_exe.py 打出的 onedir 压缩包，大，绝不入库)
/fxapk-gui-*.zip
# jadx 独立插件包 zip(build_jadx_addon.py 打出，含 JRE，大，绝不入库)+ 解压落地目录
/fxapk-jadx-*.zip
/jadx-addon/

# adb 下载缓存(build_exe.py 下 Google platform-tools 解压取 adb.exe + 2 dll)
/.platform_tools/

# 内置 frida-server 下载缓存(build_exe.py 下各 ABI 的 frida-server-*.xz，随包进 _internal，大，不入库)
/.frida_servers/

# 入口自检临时 venv(用 mangled 路径建的一次性 venv，绝不入库)
*.tmp_epcheck/

# 烟测/分析输出目录(任何 out_* 变体，绝不入库；注意 out/ 已在上方单列)
out_exe/
out_exe*/
out_chk/
out_review/
/out_*/

